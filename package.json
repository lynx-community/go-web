    "type": "git",
    "url": "https://github.com/lynx-community/go-web.git"
  },
  "license": "Apache-2.0",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./adapters/rspress": "./src/adapters/rspress.tsx",
    "./ssg": "./src/ssg.tsx",
    "./embed": "./src/embed.ts"
  },
  "main": "src/index.ts",
  "types": "src/index.ts",
  "files": [
    "src"
  ],
  "scripts": {
    "dev": "cd example && pnpm install && pnpm dev",
